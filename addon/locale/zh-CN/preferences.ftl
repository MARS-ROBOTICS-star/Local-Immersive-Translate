pref-title = 通用
pref-enable-autoTranslate =
    .label = 是否启用自动翻译
pref-enable-compatibility =
    .label = 启用兼容模式
pref-enable-compatibility-description = 启用后将会改善 PDF 兼容性，但是会增大输出文件大小
pref-enable-autoExtractGlossary =
    .label = 自动提取术语
pref-enable-autoExtractGlossary-description = 可以提升专有名词翻译一致性，但会让 Token 消耗量翻倍
pref-enable-richTextTranslate =
    .label = 富文本翻译
pref-enable-ocr-workaround = 启用 OCR 临时解决方案
pref-enable-ocr-workaround-description = 当您的扫描/图片版 PDF 文件已进行 OCR 处理，且为白底黑字时，可以尝试启用 OCR 版的临时解决方案。该方案将在译文下方添加白色矩形块，以覆盖原文内容。
pref-local-backend-settings = 本地 BabelDOC
pref-local-backend-description = 请先运行本地后端安装脚本，然后点击“启动/测试”。插件会自动识别标准安装路径。
pref-local-backend-url = 本地服务地址
pref-local-backend-autostart =
    .label = 测试或翻译前自动启动本地 BabelDOC 服务
pref-local-backend-advanced-description = 高级兜底设置。只有在你把后端安装到自定义位置，或自动识别失败时才需要填写。
pref-local-backend-project-dir = 项目目录
pref-local-backend-uv-path = uv 路径
pref-local-model-configs = 模型 API 配置
pref-local-model-configs-description = 只需要填写你实际使用的模型。插件会在翻译时把当前所选模型的配置发送给本地 BabelDOC 后端；未填写时使用本地服务配置文件中的同名模型配置。
pref-local-model-provider = 模型
pref-local-model-base-url = API 地址
pref-local-model-name = 模型名
pref-local-model-api-key = API Key
pref-customSystemPrompt = 自定义角色提示词
pref-translate-model = 翻译模型
pref-translate-mode = 翻译模式
pref-target-language = 目标语言
pref-font-family = 字体
pref-dual-mode = 双语对照显示方式
pref-layout-model = 布局识别模型
pref-test-button = 启动/测试
pref-enable-autoOpenPDF =
    .label = 自动打开翻译后的 PDF
pref-enable-autoTranslate-description = 启用后将会自动翻译新添加的 PDF 文件，无法解析为条目的 PDF 文件暂不支持自动翻译
pref-shortcuts-settings = 快捷键
pref-enable-shortcuts =
    .label = 启用快捷键
pref-shortcuts-description = 默认快捷键在 Windows/Linux 使用 Ctrl，在 macOS 使用 Cmd。清空某一项只会停用该动作。
pref-shortcut-translate = 翻译所选条目快捷键
pref-shortcut-task-manager = 打开翻译任务管理器快捷键
pref-shortcut-reset =
    .label = 恢复默认
pref-shortcut-duplicate-error = 该快捷键已被另一个插件动作使用。插件快捷键不能重复。
pref-shortcut-conflict-guidance = 自定义快捷键可能与 Zotero 或系统快捷键冲突。除 Zotero 条目列表原生使用的 Shift+字母 外，插件不会因此阻止保存。

pref-translate-settings = 翻译

pref-translate-settings-advance = 高级选项

pref-about = 关于

pref-about-feedback =
    .value = GitHub
pref-about-docs =
    .value = 文档
pref-about-version =
    .value = { $name } 版本 { $version } Build { $time }
